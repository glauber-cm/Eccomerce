<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Ecommerce</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header>
        <!--Barra principal-->
        <nav class="navbar navbar-expand-lg ecommerce-header">
            <div class="container-fluid px-4">
                <a class="navbar-brand ecommerce-logo" asp-controller="Home" asp-action="Index"><i class="bi bi-bag-check-fill"></i>EcomStore</a>

                <!--Pesquisa-->
                <form class="search-container"
                      asp-controller="Loja"
                      asp-action="Index"
                      method="get">
                    <input type="search" name="busca" class="form-control search-input" placeholder="Pesquisar produtos..." value="@Context.Request.Query["busca"]" />
                    <button class="btn search-button"
                           type="submit">
                    <i class="bi bi-search"></i>
                </button>
            </form>


            <button class="navbar-toggler bg-light" type="button" data-bs-toggle="collapse" data-bs-target="#menuPrincipal">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="menuPrincipal">
                <ul class="navbar-nav ms-auto align-items-lg-center">

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-white" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i>
                                <span>Olá, @(User.Identity.Name ?? "Usuário")</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li>
                                    <a class="dropdown-item" asp-controller="Usuario" asp-action="MeuPerfil">
                                        <i class="bi bi-person"></i>
                                        Meu perfil
                                    </a>
                                </li>

                                <li>
                                    <a class="dropdown-item" asp-controller="Pedido" asp-action="Index">
                                        <i class="bi bi-box-seam"></i>
                                        Meus pedidos
                                    </a>
                                </li>

                                <li>
                                    <hr class="dropdown-divider" />
                                </li>

                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right"></i>
                                            Sair
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right"></i>
                                Entrar
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Account" asp-action="Register">
                                Criar conta
                            </a>
                        </li>
                    }

                    <li class="nav-item ms-lg-3">
                        <a class="nav-link cart-link" asp-controller="Carrinho" asp-action="Index">
                            <i class="bi bi-cart3"></i>
                            Carrinho
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!--Menu secundário-->

    <nav class="secondary-menu">
        <div class="container-fluid px-4">

            <ul class="nav align-items-center">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house"></i>
                        Home
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Loja" asp-action="Index">
                        Loja
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Loja" asp-action="Index" asp-route-ordenacao="menor-preco">
                        Ofertas
                    </a>
                </li>

                @if (User.Identity?.IsAuthenticated == true)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Pedido" asp-action="Index">
                            Meus pedidos
                        </a>
                    </li>
                }

                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                            Administração
                        </a>
                        <ul class="dropdown-menu">
                            <li>
                                <a class="dropdown-item" asp-controller="Dashboard" asp-action="Index">
                                    Dashboard
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" asp-controller="Produto" asp-action="Index">
                                    Produtos
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" asp-controller="Categoria" asp-action="Index">
                                    Categorias
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" asp-controller="Pedido" asp-action="Index">
                                    Pedidos
                                </a>
                            </li>

                            <li>
                                <a class="dropdown-item" asp-controller="Usuario" asp-action="Index">
                                    Usuários
                                </a>
                            </li>
                        </ul>
                    </li>
                }

            </ul>
        </div>
    </nav>
</header>

<main class="container-fluid page-content px-4">
        @RenderBody()
    </main>

    <footer class="ecommerce-footer">
        <div class="container text-center">
            <p class="mb-1">
                &copy; @DateTime.Now.Year EcomStore
            </p>

            <small>
                Compra segura, atendimento rápido e produtos selecionados.
            </small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)


</body>
</html>
