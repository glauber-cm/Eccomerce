@model Ecommerce.Web.ViewModels.ProdutoViewModel

@{
    ViewData["Title"] = "Detalhes do Produto";
}


<div class="container mt-4">

    <div class="card shadow">

        <div class="card-header bg-info text-white">
            <h3 class="mb-0">Detalhes do Produto</h3>
        </div>

        <div class="card-body">

            <dl class="row">

                <dt class="col-sm-2">Nome</dt>
                <dd class="col-sm-10">@Model.Nome</dd>    

                <dt class="col-sm-2">Descrição</dt>
                <dd class="col-sm-10">@Model.Descricao</dd>

                <dt class="col-sm-2">Preço</dt>
                <dd class="col-sm-10">R$ @Model.Preco</dd>

                <dt class="col-sm-2">Estoque</dt>
                <dd class="col-sm-10">@Model.Estoque</dd>

            </dl>

            <form asp-action="Edit">

                <input type="hidden" asp-for="Id" />

                <button type="submit" class="btn btn-warning">Editar</button>

                <a asp-action="Index" class="btn btn-secondary">Voltar</a>

            </form>
        </div>
    </div>
</div>