@model IEnumerable<Ecommerce.Domain.Entities.Produto>

@{
    ViewData["Title"] = "Produtos";
}

<h2>Produtos</h2>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-warning">
        Nenhum produto encontrado.
    </div>
}
else
{

    <a asp-action="Create"
           class="btn btn-primary mb-3">
        Novo Produto
    </a>

    <table class="table table-striped">
        <thread>
            <tr>
                <th>Nome</th>
                <th>Descrição</th>
                <th>Preço</th>
                <th>Estoque</th>
                <th>Imagem</th>
                <th>Ações</th>
            </tr>
        </thread>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Nome</td>
                    <td>@item.Descricao</td>
                    <td>@item.Preco</td>
                    <td>@item.Estoque</td>
                    <td>
                        <img src="~/images/produtos/@item.ImageUrl"
                             width="80"
                             height="80"
                             style="object-fit:cover" />
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Detalhes</a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Excluir</a>
                    </td>
                </tr>
            }

        </tbody>
    </table>
}
